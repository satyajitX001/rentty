{
  "expo": {
    "name": "RentOk",
    "slug": "rentok-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3DFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.satyajit1201.rentokapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B3DFF"
      },
      "package": "com.satyajit1201.rentokapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-font"
    ]
  }
}
